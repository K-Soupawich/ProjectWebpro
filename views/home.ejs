<!DOCTYPE html>
<html lang="th">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&family=Noto+Sans+Thai:wght@400;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', 'Noto Sans Thai', sans-serif;
        }
    </style>
    <title>Home</title>
</head>

<body style="font-family: 'Inter', 'Noto Sans Thai', sans-serif;">
    <div class="bg-[#F8F8F8] h-[78px] flex items-center border-b border-gray-300 sticky top-0 z-50">
        <div class="ml-[60px]">
            <a href="/">
                <img src="/img/logo1.png" class="w-[100px] h-[67px]">
            </a>
        </div>

        <div class=" ml-[1000px]">
            <a href="/login">
                <img src="/img/home/cart.png" class="w-[47px] h-[47px]">
            </a>
        </div>

        <div class="flex items-center justify-center mt-6 ml-2">
            <a href="/login">
                <img src="/img/home/btn_login.png" class="w-[170px]">
            </a>
        </div>
    </div>


    <div class="bg-gradient-to-tr from-[#F8F7F3] to-[#EFEBE2] flex">
        <div>
            <div class="w-[690px]">
                <h1 class="text-8xl mt-[111px] ml-[90px] font-extrabold text-[#30231D]">ความมั่นใจ</h1>
                <h1 class="text-7xl mt-[20px] ml-[90px] font-extrabold text-[#A28161]">เริ่มต้นที่การแต่งตัว</h1>

                <p class="text-xl w-[550px] mt-[25px] ml-[90px]">
                    เรานำเสนอเสื้อผ้าแฟชั่นหลากหลายสไตล์ที่คัดสรรอย่างพิถีพิถัน
                    เพื่อให้ทุกลุคของคุณโดดเด่นและมั่นใจในทุกโอกาส พร้อมใส่ใจทั้งคุณภาพ ความสบาย และดีไซน์
                    เพื่อให้ทุกชิ้นสะท้อนความเป็นตัวคุณอย่างแท้จริง</p>
                <a href="/login">
                    <img src="/img/home/btn_shop.png" class="w-[340px] ml-[45px] mt-[25px]">
                </a>
            </div>
            <div>

            </div>
        </div>


        <div class="mt-6">
            <img src="/img/home/model1.png" class="w-[722px]">
        </div>
    </div>


    <div>
        <img src="/img/home/main1.png">
    </div>

    <div class="flex h-[977px] justify-center items-center">
        <div>
            <img src="/img/home/model2.png" class="w-[621px] mr-[60px] rounded-[10px]">
        </div>

        <div>
            <div
                class="bg-gradient-to-tr from-[#A28161] to-[#65513D] w-[567px] h-[240px] mb-[20px] flex flex-col justify-center items-center text-center rounded-[10px]">
                <h1 class="text-6xl text-[#F8F7F3] font-bold">เรียบหรู ดูดี ทุกวัน</h1>
                <p class="text-3xl text-[#FFFFFF] mt-10">วันนี้ใส่อะไรดี? ใส่เราเลย</p>
            </div>

            <div>
                <img src="/img/home/model3.png" class="w-[568px] rounded-[10px]">
            </div>
        </div>
    </div>

    <!-- สินค้าตัวอย่าง -->
    <div class="bg-[#EFEBE2] pb-16">

        <h1 class="text-6xl py-16 font-bold text-[#30231D] flex justify-center">
            สินค้าตัวอย่าง
        </h1>

        <div class="relative max-w-[1100px] mx-auto">

            <!-- ปุ่มซ้าย -->
            <button id="prevBtn" class="absolute -left-[100px] top-1/2 -translate-y-1/2">
                <img src="/img/home/left_button.png" class="w-[58px]">
            </button>
            <div class="overflow-x-hidden overflow-y-visible pb-8">
                <div id="slider" class="flex transition-transform duration-500 ease-in-out">

                    <% products.forEach(product=> { %>
                        <div class="product-card w-[326px] mx-5 flex-shrink-0 bg-white rounded-2xl shadow-[0_8px_20px_rgba(0,0,0,0.08)] p-2">

                            <div class="flex justify-center items-center">
                                <div class="bg-white w-[286px] h-[230px] rounded-[12px] flex justify-center overflow-hidden items-center shadow-[0_6px_20px_rgba(0,0,0,0.15)] mt-[18px]">
                                    <img src="/uploads/<%= product.image %>" class="w-[212px] object-contain">
                                </div>
                            </div>

                            <div class="flex flex-col">
                                <p class="ml-[28px] mt-[19px]">
                                    <%= product.name %>
                                </p>

                                <div class="flex mt-[10px]">
                                    <h2 class="ml-[28px] mr-[200px]">
                                        ฿<%= product.price %>
                                    </h2>

                                    <a href="/login">
                                        <img src="/img/home/cart.png" class="w-[26.65px]">
                                    </a>
                                </div>
                            </div>
                        </div>
                        <% }) %>
                </div>
            </div>

            <!-- ปุ่มขวา -->
            <button id="nextBtn" class="absolute -right-[100px] top-1/2 -translate-y-1/2">
                <img src="/img/home/right_button.png" class="w-[58px]">
            </button>

        </div>

    </div>

    <!-- Footer ข้อมูลติดต่อ -->
    <footer class="bg-gradient-to-tr from-[#A28161] to-[#65513D] py-14 px-10">
        <div class="max-w-[1100px] mx-auto">

            <h2 class="text-white text-[32px] font-bold mb-10">ติดต่อเรา</h2>

            <div class="flex flex-wrap gap-12">

                <div class="text-white min-w-[260px]">
                    <p class="text-white/60 text-[12px] uppercase tracking-widest mb-3">ที่อยู่</p>
                    <p class="text-[15px] leading-7">
                        เลขที่ 1 ซอยฉลองกรุง 1<br>
                        แขวงลาดกระบัง เขตลาดกระบัง<br>
                        กรุงเทพฯ 10520
                    </p>
                </div>

                <div class="text-white min-w-[240px]">
                    <p class="text-white/60 text-[12px] uppercase tracking-widest mb-3">ช่องทางติดต่อ</p>
                    <div class="flex flex-col gap-3">

                        <div class="flex items-center gap-3">
                            <div class="w-9 h-9 bg-white/20 rounded-full flex items-center justify-center flex-shrink-0">
                                <svg class="w-4 h-4" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24">
                                    <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498A1 1 0 0121 17.72V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                                </svg>
                            </div>
                            <span class="text-[15px]">099-999-9999</span>
                        </div>

                        <div class="flex items-center gap-3">
                            <div class="w-9 h-9 bg-white/20 rounded-full flex items-center justify-center flex-shrink-0">
                                <svg class="w-4 h-4" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24">
                                    <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                                </svg>
                            </div>
                            <span class="text-[15px]">kofy@gmail.com</span>
                        </div>

                    </div>
                </div>

                <div class="text-white min-w-[200px]">
                    <p class="text-white/60 text-[12px] uppercase tracking-widest mb-3">โซเชียลมีเดีย</p>
                    <div class="flex flex-col gap-3">

                        <div class="flex items-center gap-3">
                            <div class="w-9 h-9 bg-white/20 rounded-full flex items-center justify-center flex-shrink-0">
                                <svg class="w-4 h-4 fill-white" viewBox="0 0 24 24">
                                    <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
                                </svg>
                            </div>
                            <span class="text-[15px]">KOFY Official</span>
                        </div>

                        <div class="flex items-center gap-3">
                            <div class="w-9 h-9 bg-white/20 rounded-full flex items-center justify-center flex-shrink-0">
                                <svg class="w-4 h-4" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24">
                                    <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                                    <circle cx="12" cy="12" r="4"/>
                                    <circle cx="17.5" cy="6.5" r="1" fill="white" stroke="none"/>
                                </svg>
                            </div>
                            <span class="text-[15px]">@kofy.store</span>
                        </div>

                    </div>
                </div>

            </div>

        </div>
    </footer>

        <script>
            const slider = document.getElementById("slider");
            const nextBtn = document.getElementById("nextBtn");
            const prevBtn = document.getElementById("prevBtn");

            const cardWidth = 326 + 40; // 326px + gap-10(40px)
            let index = 0;

            const maxIndex = slider.children.length - 3; // แสดง 3 ใบ

            nextBtn.addEventListener("click", () => {
                if (index < maxIndex) {
                    index++;
                    slider.style.transform = `translateX(-${index * cardWidth}px)`;
                }
            });

            prevBtn.addEventListener("click", () => {
                if (index > 0) {
                    index--;
                    slider.style.transform = `translateX(-${index * cardWidth}px)`;
                }
            });
        </script>
    </body>

</html>