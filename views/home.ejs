<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&family=Noto+Sans+Thai:wght@400;600;700;800;900&display=swap"
        rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', 'Noto Sans Thai', sans-serif;
        }
    </style>
    <title>Home</title>
</head>

<body style="font-family: 'Inter', 'Noto Sans Thai', sans-serif;">
    <div class="bg-[#F8F8F8] h-[78px] flex items-center border-b border-gray-300 sticky top-0 z-50">
        <div class="ml-[60px]">
            <a href="/">
                <img src="/img/home/logo1.png" class="w-[100px] h-[67px]">
            </a>
        </div>

        <div class=" ml-[1000px]">
            <a href="/">
                <img src="/img/home/cart.png" class="w-[47px] h-[47px]">
            </a>
        </div>

        <div class="flex items-center justify-center mt-6 ml-2">
            <a href="/login">
                <img src="/img/home/btn_login.png" class="w-[170px]">
            </a>
        </div>
    </div>


    <div class="bg-gradient-to-tr from-[#F8F7F3] to-[#EFEBE2] flex">
        <div>
            <div class="w-[690px]">
                <h1 class="text-8xl mt-[111px] ml-[90px] font-extrabold text-[#30231D]">ความมั่นใจ</h1>
                <h1 class="text-7xl mt-[20px] ml-[90px] font-extrabold text-[#A28161]">เริ่มต้นที่การแต่งตัว</h1>

                <p class="text-xl w-[550px] mt-[25px] ml-[90px]">
                    เรานำเสนอเสื้อผ้าแฟชั่นหลากหลายสไตล์ที่คัดสรรอย่างพิถีพิถัน
                    เพื่อให้ทุกลุคของคุณโดดเด่นและมั่นใจในทุกโอกาส พร้อมใส่ใจทั้งคุณภาพ ความสบาย และดีไซน์
                    เพื่อให้ทุกชิ้นสะท้อนความเป็นตัวคุณอย่างแท้จริง</p>
                <a href="/login">
                    <img src="/img/home/btn_shop.png" class="w-[340px] ml-[45px] mt-[25px]">
                </a>
            </div>
            <div>

            </div>
        </div>


        <div class="mt-6">
            <img src="/img/home/model1.png" class="w-[722px]">
        </div>
    </div>


    <div>
        <img src="/img/home/main1.png">
    </div>

    <div class="flex h-[977px] justify-center items-center">
        <div>
            <img src="/img/home/model2.png" class="w-[621px] mr-[60px] rounded-[10px]">
        </div>

        <div>
            <div
                class="bg-gradient-to-tr from-[#A28161] to-[#65513D] w-[567px] h-[240px] mb-[20px] flex flex-col justify-center items-center text-center rounded-[10px]">
                <h1 class="text-6xl text-[#F8F7F3] font-bold">เรียบหรู ดูดี ทุกวัน</h1>
                <p class="text-3xl text-[#FFFFFF] mt-10">วันนี้ใส่อะไรดี? ใส่เราเลย</p>
            </div>

            <div>
                <img src="/img/home/model3.png" class="w-[568px] rounded-[10px]">
            </div>
        </div>
    </div>

    <!-- สินค้าตัวอย่าง -->
    <div class="bg-[#EFEBE2] h-[627px]">

        <h1 class="text-6xl py-16 font-bold text-[#30231D] flex justify-center">
            สินค้าตัวอย่าง
        </h1>

        <div class="relative max-w-[1100px] mx-auto">

            <!-- ปุ่มซ้าย -->
            <button id="prevBtn" class="absolute -left-[100px] top-1/2 -translate-y-1/2">
                <img src="/img/home/left_button.png" class="w-[58px]">
            </button>
            <div class="overflow-x-hidden overflow-y-visible pb-8">
                <div id="slider" class="flex transition-transform duration-500 ease-in-out">

                    <% products.forEach(product=> { %>
                        <div class="product-card w-[326px] mx-5 flex-shrink-0 bg-white rounded-2xl shadow-[0_8px_20px_rgba(0,0,0,0.08)] p-2">

                            <div class="flex justify-center items-center">
                                <div class="bg-white w-[284px] h-[230px] rounded-[12px] flex justify-center items-center shadow-[0_6px_20px_rgba(0,0,0,0.15)] mt-[18px]">
                                    <img src="/uploads/<%= product.image %>" class="w-[212px] object-contain">
                                </div>
                            </div>

                            <div class="flex flex-col">
                                <p class="ml-[28px] mt-[19px]">
                                    <%= product.name %>
                                </p>

                                <div class="flex mt-[10px]">
                                    <h2 class="ml-[28px] mr-[200px]">
                                        ฿<%= product.price %>
                                    </h2>

                                    <a href="/login">
                                        <img src="/img/home/cart.png" class="w-[26.65px]">
                                    </a>
                                </div>
                            </div>
                        </div>
                        <% }) %>
                </div>
            </div>

            <!-- ปุ่มขวา -->
            <button id="nextBtn" class="absolute -right-[100px] top-1/2 -translate-y-1/2">
                <img src="/img/home/right_button.png" class="w-[58px]">
            </button>

        </div>

        <script>
            const slider = document.getElementById("slider");
            const nextBtn = document.getElementById("nextBtn");
            const prevBtn = document.getElementById("prevBtn");

