<!DOCTYPE html>
<html lang="th">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Thai:wght@400;500;600;700&family=IBM+Plex+Mono:wght@500&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'IBM Plex Sans Thai', sans-serif; }
        .mono { font-family: 'IBM Plex Mono', monospace; }
    </style>
    <title>แดชบอร์ด – KOFY</title>
</head>

<body class="flex bg-[#F5F3EF] h-screen overflow-hidden">

    <%- include('partials/sidebar') %>

        <div class="flex-1 flex flex-col h-screen overflow-y-auto">
                <div class="flex-shrink-0 bg-[#F5F3EF] border-b border-[#E8E0D5]
                px-4 md:px-10 h-[62px] flex items-center justify-between gap-3">

                    <h1 class="hidden md:block text-[18px] font-bold text-[#30231D] tracking-tight whitespace-nowrap">
                        แดชบอร์ด
                    </h1>

            <p class="text-[12px] text-[#A28161] mono"><%= new Date().toLocaleDateString('th-TH', { weekday:'long', year:'numeric', month:'long', day:'numeric' }) %></p>
        </div>

        <div class="px-10 py-8 space-y-6">

            <!-- ===== KPI CARDS ===== -->
            <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">

                <!-- รายได้ทั้งหมด -->
                <div class="bg-white rounded-2xl border border-[#E8E0D5] shadow-sm px-5 py-4 flex items-center gap-4">
                    <img src="/img/dashboard/รายได้ทั้งหมด.png" class="w-11 h-11 flex-shrink-0">
                    <div>
                        <p class="text-[10px] font-semibold text-[#999] uppercase tracking-wider">รายได้ทั้งหมด</p>
                        <p class="text-[22px] font-bold text-[#30231D] leading-tight mono">
                            <%=  stats.totalRevenue.toLocaleString() %>
                        </p>
                        <p class="text-[11px] text-[#A28161]">บาท</p>
                    </div>
                </div>

                <!-- ออเดอร์วันนี้ -->
                <div class="bg-white rounded-2xl border border-[#E8E0D5] shadow-sm px-5 py-4 flex items-center gap-4">
                    <img src="/img/dashboard/ออเดอร์วันนี้.png" class="w-11 h-11 flex-shrink-0">
                    <div>
                        <p class="text-[10px] font-semibold text-[#999] uppercase tracking-wider">ออเดอร์วันนี้</p>
                        <p class="text-[22px] font-bold text-[#30231D] leading-tight mono"><%= stats.todayOrders %></p>
                        <p class="text-[11px] text-[#A28161]">รายการ</p>
                    </div>
                </div>

                <!-- รายได้เดือนนี้ -->
                <div class="bg-white rounded-2xl border border-[#E8E0D5] shadow-sm px-5 py-4 flex items-center gap-4">
                    <img src="/img/dashboard/รายได้เดือนนี้.png" class="w-11 h-11 flex-shrink-0">
                    <div>
                        <p class="text-[10px] font-semibold text-[#999] uppercase tracking-wider">รายได้เดือนนี้</p>
                        <p class="text-[22px] font-bold text-[#30231D] leading-tight mono">
                            <%= stats.monthRevenue.toLocaleString() %>
                        </p>
                        <p class="text-[11px] text-[#A28161]">บาท</p>
                    </div>
                </div>

                <!-- ออเดอร์รอดำเนินการ -->
                <div class="bg-white rounded-2xl border border-[#E8E0D5] shadow-sm px-5 py-4 flex items-center gap-4">
                    <img src="/img/dashboard/รอดำเนินการ.png" class="w-11 h-11 flex-shrink-0">
                    <div>
                        <p class="text-[10px] font-semibold text-[#999] uppercase tracking-wider">รอดำเนินการ</p>
                        <p class="text-[22px] font-bold text-[#30231D] leading-tight mono"><%= stats.pendingOrders %></p>
                        <p class="text-[11px] text-[#A28161]">ออเดอร์</p>
                    </div>
                </div>

            </div>

            <!-- Row 2 -->
            <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">

                <div class="bg-white rounded-2xl border border-[#E8E0D5] shadow-sm px-5 py-4 flex items-center gap-4">
                    <img src="/img/dashboard/หมวดหมู่ทั้งหมด.png" class="w-11 h-11 flex-shrink-0">
                    <div>
                        <p class="text-[10px] font-semibold text-[#999] uppercase tracking-wider">หมวดหมู่</p>
                        <p class="text-[22px] font-bold text-[#30231D] leading-tight mono"><%= stats.totalCategories %></p>
                        <p class="text-[11px] text-[#A28161]">หมวด</p>
                    </div>
                </div>

                <div class="bg-white rounded-2xl border border-[#E8E0D5] shadow-sm px-5 py-4 flex items-center gap-4">
                    <img src="/img/dashboard/สินค้าทั้งหมด.png" class="w-11 h-11 flex-shrink-0">
                    <div>
                        <p class="text-[10px] font-semibold text-[#999] uppercase tracking-wider">สินค้าทั้งหมด</p>
                        <p class="text-[22px] font-bold text-[#30231D] leading-tight mono"><%= stats.totalProducts %></p>
                        <p class="text-[11px] text-[#A28161]">รายการ</p>
                    </div>
                </div>

                <div class="bg-white rounded-2xl border border-[#E8E0D5] shadow-sm px-5 py-4 flex items-center gap-4">
                    <img src="/img/dashboard/ลูกค้าทั้งหมด.png" class="w-11 h-11 flex-shrink-0">
                    <div>
                        <p class="text-[10px] font-semibold text-[#999] uppercase tracking-wider">ลูกค้าทั้งหมด</p>
                        <p class="text-[22px] font-bold text-[#30231D] leading-tight mono"><%= stats.totalCustomers %></p>
                        <p class="text-[11px] text-[#A28161]">คน</p>
                    </div>
                </div>

                <div class="bg-white rounded-2xl border border-[#E8E0D5] shadow-sm px-5 py-4 flex items-center gap-4">
                    <img src="/img/dashboard/สต็อกต่ำ.png" class="w-11 h-11 flex-shrink-0">
                    <div>
                        <p class="text-[10px] font-semibold text-[#999] uppercase tracking-wider">สต็อกต่ำ</p>
                        <p class="text-[22px] font-bold <%= stats.lowStock > 0 ? 'text-red-500' : 'text-[#30231D]' %> leading-tight mono">
                            <%= stats.lowStock %>
                        </p>
                        <p class="text-[11px] text-[#A28161]">(≤10 ชิ้น)</p>
                    </div>
                </div>

            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

                <!-- สินค้าในแต่ละหมวด -->
                <div class="bg-white rounded-2xl border border-[#E8E0D5] shadow-sm overflow-hidden">
                    <div class="px-5 py-3.5 border-b border-[#E8E0D5] bg-[#FDFCF9]">
                        <p class="text-[11px] font-semibold text-[#A28161] uppercase tracking-widest">จำนวนสินค้าในแต่ละหมวด</p>
                    </div>
                    <% productsByCategory.forEach((cat, idx) => { %>
                    <div class="flex items-center justify-between px-5 py-3 border-b border-[#F0EBE3] last:border-b-0
                        <%= idx % 2 === 0 ? '' : 'bg-[#FDFCF9]' %>">
                        <div class="flex items-center gap-3">
                            <span class="mono text-[10px] text-[#A28161] bg-[#F0EBE3] px-2 py-0.5 rounded-md"><%= cat.code %></span>
                            <span class="text-[13px] text-[#30231D]"><%= cat.name %></span>
                        </div>
                        <div class="flex items-center gap-3">
                            <div class="w-[80px] bg-[#F0EBE3] rounded-full h-1.5">
                                <div class="bg-[#A28161] h-1.5 rounded-full"
                                    style="width: <%= Math.min(100, (cat.product_count / (productsByCategory[0]?.product_count || 1)) * 100) %>%">
                                </div>
                            </div>
                            <span class="mono text-[13px] font-bold text-[#30231D] w-6 text-right"><%= cat.product_count %></span>
                        </div>
                    </div>
                    <% }) %>
                </div>

                <!-- ยอดขาย 7 วัน -->
                <div class="bg-white rounded-2xl border border-[#E8E0D5] shadow-sm overflow-hidden">
                    <div class="px-5 py-3.5 border-b border-[#E8E0D5] bg-[#FDFCF9] flex items-center justify-between">
                        <p class="text-[11px] font-semibold text-[#A28161] uppercase tracking-widest">ยอดขาย 7 วัน</p>
                        <p class="mono text-[11px] text-[#999]">รวม ฿<%= salesLast7Days.reduce((s,d)=>s+d.total,0).toLocaleString() %></p>
                    </div>
                    <div class="px-5 py-4">
                        <canvas id="salesChart" height="160"></canvas>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 pb-8">

                <!-- สินค้าขายดี -->
                <div class="bg-white rounded-2xl border border-[#E8E0D5] shadow-sm overflow-hidden">
                    <div class="px-5 py-3.5 border-b border-[#E8E0D5] bg-[#FDFCF9]">
                        <p class="text-[11px] font-semibold text-[#A28161] uppercase tracking-widest">สินค้าขายดี (30 วัน)</p>
                    </div>
                    <% if (topProducts.length === 0) { %>
                    <div class="py-10 text-center text-[13px] text-[#C5BAB0]">ยังไม่มีข้อมูล</div>
                    <% } %>
                    <% topProducts.forEach((p, idx) => { %>
                    <div class="flex items-center gap-3 px-5 py-3 border-b border-[#F0EBE3] last:border-b-0
                        <%= idx % 2 === 0 ? '' : 'bg-[#FDFCF9]' %>">
                        <span class="mono text-[11px] text-[#C5BAB0] w-4 text-center"><%= idx+1 %></span>
                        <img src="/uploads/<%= p.image || '' %>"
                            onerror="this.src='/img/profile/default.png'"
                            class="w-9 h-9 rounded-lg object-cover border border-[#E8E0D5] flex-shrink-0">
                        <div class="flex-1 min-w-0">
                            <p class="text-[13px] font-semibold text-[#30231D] truncate"><%= p.name %></p>
                            <p class="mono text-[10px] text-[#A28161]"><%= p.sku %></p>
                        </div>
                        <div class="text-right flex-shrink-0">
                            <p class="mono text-[12px] font-bold text-[#30231D]"><%= p.total_sold %> ชิ้น</p>
                            <p class="text-[10px] text-[#999]">฿<%= p.total_revenue.toLocaleString() %></p>
                        </div>
                    </div>
                    <% }) %>
                </div>

                <!-- ออเดอร์ล่าสุด -->
                <div class="bg-white rounded-2xl border border-[#E8E0D5] shadow-sm overflow-hidden">
                    <div class="px-5 py-3.5 border-b border-[#E8E0D5] bg-[#FDFCF9] flex items-center justify-between">
                        <p class="text-[11px] font-semibold text-[#A28161] uppercase tracking-widest">ออเดอร์ล่าสุด</p>
                        <a href="/orders" class="text-[11px] text-[#A28161] hover:text-[#6E5742] transition">ดูทั้งหมด →</a>
                    </div>

                    <div class="grid grid-cols-[70px_1fr_110px_90px] px-5 py-2 bg-[#FDFCF9] border-b border-[#E8E0D5]
                        text-[10px] font-semibold text-[#999] uppercase tracking-widest">
                        <div>ออเดอร์</div>
                        <div>ลูกค้า</div>
                        <div class="text-right">ยอดรวม</div>
                        <div class="text-center">สถานะ</div>
                    </div>

                    <% const stCls = {
                        pending: 'bg-yellow-50 text-yellow-600',
                        confirmed: 'bg-blue-50 text-blue-600',
                        shipped: 'bg-indigo-50 text-indigo-600',
                        delivered: 'bg-green-50 text-green-600',
                        cancelled: 'bg-red-50 text-red-500',
                    };
                    const stLabel = {
                        pending: 'รอ', confirmed: 'ยืนยัน', shipped: 'จัดส่ง', delivered: 'สำเร็จ', cancelled: 'ยกเลิก'
                    }; %>

                    <% if (recentOrders.length === 0) { %>
                    <div class="py-10 text-center text-[13px] text-[#C5BAB0]">ยังไม่มีออเดอร์</div>
                    <% } %>

                    <% recentOrders.forEach((o, idx) => { %>
                    <div class="grid grid-cols-[70px_1fr_110px_90px] items-center px-5 py-3
                        border-b border-[#F0EBE3] last:border-b-0
                        <%= idx % 2 === 0 ? '' : 'bg-[#FDFCF9]' %>">
                        <div class="mono text-[12px] font-semibold text-[#A28161]">#<%= o.id %></div>
                        <div class="text-[12px] text-[#30231D] truncate pr-2"><%= o.username %></div>
                        <div class="mono text-[12px] font-semibold text-[#30231D] text-right">฿<%= o.total_amount.toLocaleString() %></div>
                        <div class="flex justify-center">
                            <span class="text-[10px] font-semibold px-2 py-0.5 rounded-full <%= stCls[o.status] || 'bg-gray-100 text-gray-500' %>">
                                <%= stLabel[o.status] || o.status %>
                            </span>
                        </div>
                    </div>
                    <% }) %>
                </div>

            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script id="salesData" type="application/json"><%- JSON.stringify(salesLast7Days) %></script>
    <script>
        const sales = JSON.parse(document.getElementById('salesData').textContent);
        const ctx = document.getElementById('salesChart').getContext('2d');

        new Chart(ctx, {
            type: 'line',
            data: {
                labels: sales.map(d => d.label),
                datasets: [{
                    data: sales.map(d => d.total),
                    borderColor: '#A28161',
                    backgroundColor: 'rgba(162,129,97,0.08)',
                    borderWidth: 2,
                    pointBackgroundColor: '#A28161',
                    pointRadius: 4,
                    tension: 0.35,
                    fill: true,
                }]
            },
            options: {
                plugins: { legend: { display: false } },
                scales: {
                    x: { grid: { display: false }, ticks: { font: { size: 11 }, color: '#aaa' } },
                    y: {
                        grid: { color: '#F0EBE3' },
                        ticks: {
                            font: { size: 11 }, color: '#aaa',
                            callback: v => '฿' + v.toLocaleString()
                        }
                    }
                }
            }
        });
    </script>

</body>
</html>
