<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Thai:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <title>จัดการผู้ใช้</title>
    <style>
        body {
            font-family: 'IBM Plex Sans Thai', sans-serif;
        }

        .mono {
            font-family: 'IBM Plex Mono', monospace;
        }
    </style>
</head>
<body class="flex bg-[#F5F3EF] min-h-screen ">

    <%- include('partials/sidebar')%>

    <div class="flex-1 flex flex-col overflow-hidden">

        <div class="flex-shrink-0 bg-[#F5F3EF] border-b border-[#E8E0D5]
            px-4 md:px-10 h-[62px] flex items-center justify-between gap-3">

            <h1 class="text-[22px] font-semibold text-[#30231D]">
                จัดการผู้ใช้
            </h1>
            <button onclick="openCreateModal()"
                class="bg-[#6E5742] hover:bg-[#5a4535] text-white text-[14px] font-medium px-5 py-2.5 rounded-lg transition flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M12 5v14M5 12h14"/>
                </svg>
                เพิ่มผู้ใช้
                
            </button>
        </div>

        <div class="flex-1 px-8 py-6">

            <% if (success) { %>
            <div id="flashMsg" class="mb-4 bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg text-[14px] flex items-center justify-between">
                <span>✓ <%= success %></span>
                <button onclick="this.parentElement.remove()" class="text-green-400 hover:text-green-600">✕</button>
            </div>
            <% } %>
            <% if (error) { %>
            <div id="flashMsg" class="mb-4 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg text-[14px] flex items-center justify-between">
                <span>✕ <%= error %></span>
                <button onclick="this.parentElement.remove()" class="text-red-400 hover:text-red-600">✕</button>
            </div>
            <% } %>

            <!-- Search + filter -->
            <div class="flex items-center gap-3 mb-5">
                <div class="relative flex-1 max-w-[320px]">
                    <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-[#A28161]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
                    </svg>
                    <input id="searchInput" type="text" placeholder="ค้นหาผู้ใช้..."
                        class="w-full pl-10 pr-4 py-2.5 bg-white border border-[#E0D5C8] rounded-lg text-[14px] focus:outline-none focus:border-[#A28161] text-[#30231D]"
                        oninput="filterTable()">
                </div>
                <select id="roleFilter" onchange="filterTable()"
                    class="bg-white border border-[#E0D5C8] rounded-lg text-[14px] px-3 py-2.5 text-[#30231D] focus:outline-none focus:border-[#A28161]">
                    <option value="">ทุก Role</option>
                    <option value="admin">Admin</option>
                    <option value="staff">Staff</option>
                    <option value="customer">Customer</option>
                </select>
            </div>

            <!-- Table -->
            <div class="bg-white rounded-xl border border-[#E0D5C8] overflow-hidden">
                <table class="w-full">
                    <thead>
                        <tr class="bg-[#F5F0EA] border-b border-[#E0D5C8]">
                            <th class="text-left text-[12px] font-semibold text-[#A28161] uppercase tracking-wider px-6 py-3">ผู้ใช้</th>
                            <th class="text-left text-[12px] font-semibold text-[#A28161] uppercase tracking-wider px-4 py-3">อีเมล</th>
                            <th class="text-left text-[12px] font-semibold text-[#A28161] uppercase tracking-wider px-4 py-3">สิทธิ์</th>
                            <th class="text-left text-[12px] font-semibold text-[#A28161] uppercase tracking-wider px-4 py-3">สถานะ</th>
                            <th class="text-right text-[12px] font-semibold text-[#A28161] uppercase tracking-wider px-6 py-3">จัดการ</th>
                        </tr>
                    </thead>
                    <tbody id="userTable">
                        <% users.forEach((u, i) => { %>
                        <tr class="user-row border-b border-[#F0EBE3] hover:bg-[#FDFAF7] transition"
                            data-name="<%= u.username.toLowerCase() %>"
                            data-email="<%= u.email.toLowerCase() %>"
                            data-role="<%= u.role %>">
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-3">
                                    <div class="w-9 h-9 rounded-full bg-[#E8DDD3] flex items-center justify-center flex-shrink-0 overflow-hidden">
                                        <% if (u.avatar && u.avatar !== 'default.png') { %>
                                        <img src="/img/profile/<%= u.avatar %>" class="w-full h-full object-cover" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                                        <span style="display:none" class="text-[#A28161] text-[13px] font-semibold w-full h-full flex items-center justify-center"><%= u.username[0].toUpperCase() %></span>
                                        <% } else { %>
                                        <span class="text-[#A28161] text-[13px] font-semibold"><%= u.username[0].toUpperCase() %></span>
                                        <% } %>
                                    </div>
                                    <div>
                                        <p class="text-[14px] font-medium text-[#30231D]"><%= u.username %></p>
                                        <% if (u.phone) { %>
                                        <p class="text-[12px] text-[#A28161]"><%= u.phone %></p>
                                        <% } %>
                                    </div>
                                </div>
                            </td>
                            <td class="px-4 py-4 text-[14px] text-[#5a4535]"><%= u.email %></td>
                            <td class="px-4 py-4">
                                <% if (u.role === 'admin') { %>
                                <span class="bg-[#30231D] text-white text-[11px] font-medium px-2.5 py-1 rounded-full">Admin</span>
                                <% } else if (u.role === 'staff') { %>
                                <span class="bg-[#E8DDD3] text-[#6E5742] text-[11px] font-medium px-2.5 py-1 rounded-full">Staff</span>
                                <% } else { %>
                                <span class="bg-[#EAF4EA] text-[#3a7a3a] text-[11px] font-medium px-2.5 py-1 rounded-full">Customer</span>
                                <% } %>
                            </td>
                            <td class="px-4 py-4">
                                <% if (u.id === currentUser.id) { %>
                                <span class="bg-blue-50 text-blue-600 text-[11px] font-medium px-2.5 py-1 rounded-full">ใช้งานอยู่</span>
                                <% } %>
                            </td>
                            <td class="px-6 py-4 text-right">
                                <div class="flex items-center justify-end gap-2">
                                    <button onclick='openEditModal(
                                    <%= JSON.stringify({id: u.id, username: u.username, email: u.email, phone: u.phone || "", role: u.role}) %>)'
                                        class="text-[#A28161] hover:text-[#6E5742] hover:bg-[#F0EBE3] p-1.5 rounded-lg transition" title="แก้ไข">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                            <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/>
                                            <path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                        </svg>
                                    </button>
                                    <% if (u.id !== currentUser.id) { %>
                                    <button onclick="confirmDelete(<%= u.id %>, '<%= u.username %>')"
                                        class="text-red-300 hover:text-red-500 hover:bg-red-50 p-1.5 rounded-lg transition" title="ลบ">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                            <polyline points="3 6 5 6 21 6"/>
                                            <path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/>
                                            <path d="M10 11v6M14 11v6M9 6V4a1 1 0 011-1h4a1 1 0 011 1v2"/>
                                        </svg>
                                    </button>
                                    <% } %>
                                </div>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>

                <% if (users.length === 0) { %>
                <div class="text-center py-16 text-[#A28161] text-[14px]">ยังไม่มีผู้ใช้</div>
                <% } %>
            </div>

            <p class="text-[12px] text-[#A28161] mt-3">ทั้งหมด <%= users.length %> คน</p>
        </div>
    </div>

    <!-- Create -->
    <div id="createModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40">
        <div class="bg-white rounded-2xl shadow-xl w-[460px] p-7">
            <div class="flex items-center justify-between mb-6">
                <h2 class="text-[18px] font-semibold text-[#30231D]">
                    เพิ่มผู้ใช้ใหม่
                </h2>

                <button onclick="closeCreateModal()" class="text-[#A28161] hover:text-[#6E5742] p-1">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 6 6 18M6 6l12 12"/></svg>
                </button>
            </div>

            <form action="/users/create" method="POST" class="flex flex-col gap-4">

                <!-- Role selector -->
                <div>
                    <label class="block text-[12px] font-medium text-[#A28161] mb-1.5 uppercase tracking-wider">
                        สิทธิ์
                    </label>
                    <select name="role" id="createRole" onchange="generateUsername()" required
                        class="w-full border border-[#E0D5C8] rounded-lg px-3 py-2.5 text-[14px] text-[#30231D] focus:outline-none focus:border-[#A28161]">
                        <option value="staff">Staff</option>
                        <option value="admin">Admin</option>
                        <option value="customer">Customer</option>
                    </select>
                </div>

                <!-- Username (auto-gen, editable) -->
                <div>
                    <label class="block text-[12px] font-medium text-[#A28161] mb-1.5 uppercase tracking-wider">
                        ชื่อผู้ใช้
                    </label>

                    <div class="flex gap-2">
                        <input type="text" name="username" id="createUsername" required
                            class="flex-1 border border-[#E0D5C8] rounded-lg px-3 py-2.5 text-[14px] text-[#30231D] focus:outline-none focus:border-[#A28161]"
                            placeholder="staff_1">
                        <button type="button" onclick="generateUsername()"
                            class="bg-[#F0EBE3] hover:bg-[#E0D5C8] text-[#6E5742] text-[12px] px-3 py-2.5 rounded-lg transition flex-shrink-0" title="สุ่มใหม่">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path d="M1 4v6h6M23 20v-6h-6"/><path d="M20.49 9A9 9 0 005.64 5.64L1 10M23 14l-4.64 4.36A9 9 0 013.51 15"/>
                            </svg>
                        </button>
                    </div>
                    <p class="text-[11px] text-[#A28161] mt-1">สร้างอัตโนมัติตาม format role_id แก้ไขได้</p>
                </div>

                <!-- Email -->
                <div>
                    <label class="block text-[12px] font-medium text-[#A28161] mb-1.5 uppercase tracking-wider">
                        อีเมล
                    </label>

                    <input type="email" name="email" id="createEmail" required
                        class="w-full border border-[#E0D5C8] rounded-lg px-3 py-2.5 text-[14px] text-[#30231D] focus:outline-none focus:border-[#A28161]"
                        placeholder="email@example.com">
                </div>

                <!-- Password (auto-gen, shown) -->
                <div>
                    <label class="block text-[12px] font-medium text-[#A28161] mb-1.5 uppercase tracking-wider">
                        รหัสผ่าน
                    </label>
                    <div class="flex gap-2">
                        <input type="text" name="password" id="createPassword" required readonly
                            class="flex-1 border border-[#E0D5C8] rounded-lg px-3 py-2.5 text-[14px] text-[#30231D] bg-[#FDFAF7] font-mono focus:outline-none">
                        <button type="button" onclick="generatePassword()"
                            class="bg-[#F0EBE3] hover:bg-[#E0D5C8] text-[#6E5742] text-[12px] px-3 py-2.5 rounded-lg transition flex-shrink-0" title="สุ่มใหม่">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path d="M1 4v6h6M23 20v-6h-6"/><path d="M20.49 9A9 9 0 005.64 5.64L1 10M23 14l-4.64 4.36A9 9 0 013.51 15"/>
                            </svg>
                        </button>
                        <button type="button" onclick="copyPassword()"
                            class="bg-[#F0EBE3] hover:bg-[#E0D5C8] text-[#6E5742] text-[12px] px-3 py-2.5 rounded-lg transition flex-shrink-0" title="คัดลอก">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/>
                            </svg>
                        </button>
                    </div>
                    <p class="text-[11px] text-[#A28161] mt-1">คัดลอกรหัสผ่านก่อนบันทึก เพื่อส่งให้ผู้ใช้</p>
                </div>

                <div class="flex gap-3 mt-2">
                    <button type="button" onclick="closeCreateModal()"
                        class="flex-1 border border-[#E0D5C8] text-[#6E5742] text-[14px] py-2.5 rounded-lg hover:bg-[#F0EBE3] transition">
                        ยกเลิก
                    </button>
                    <button type="submit"
                        class="flex-1 bg-[#6E5742] hover:bg-[#5a4535] text-white text-[14px] py-2.5 rounded-lg transition font-medium">
                        สร้างผู้ใช้
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Edit -->
    <div id="editModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40">
        <div class="bg-white rounded-2xl shadow-xl w-[460px] p-7">
            <div class="flex items-center justify-between mb-6">
                <h2 class="text-[18px] font-semibold text-[#30231D]">แก้ไขผู้ใช้</h2>
                <button onclick="closeEditModal()" class="text-[#A28161] hover:text-[#6E5742] p-1">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 6 6 18M6 6l12 12"/></svg>
                </button>
            </div>

            <form id="editForm" action="/users/update" method="POST" class="flex flex-col gap-4">
                <input type="hidden" name="id" id="editId">

                <div>
                    <label class="block text-[12px] font-medium text-[#A28161] mb-1.5 uppercase tracking-wider">
                        ชื่อผู้ใช้
                    </label>

                    <input type="text" name="username" id="editUsername" required
                        class="w-full border border-[#E0D5C8] rounded-lg px-3 py-2.5 text-[14px] text-[#30231D] focus:outline-none focus:border-[#A28161]">
                </div>

                <div>
                    <label class="block text-[12px] font-medium text-[#A28161] mb-1.5 uppercase tracking-wider">
                        อีเมล
                    </label>

                    <input type="email" name="email" id="editEmail" required
                        class="w-full border border-[#E0D5C8] rounded-lg px-3 py-2.5 text-[14px] text-[#30231D] focus:outline-none focus:border-[#A28161]">
                </div>

                <div>
                    <label class="block text-[12px] font-medium text-[#A28161] mb-1.5 uppercase tracking-wider">
                        เบอร์โทร
                    </label>
                    <input type="text" name="phone" id="editPhone"
                        class="w-full border border-[#E0D5C8] rounded-lg px-3 py-2.5 text-[14px] text-[#30231D] focus:outline-none focus:border-[#A28161]">
                </div>

                <div>
                    <label class="block text-[12px] font-medium text-[#A28161] mb-1.5 uppercase tracking-wider">
                        สิทธิ์
                    </label>
                    <select name="role" id="editRole"
                        class="w-full border border-[#E0D5C8] rounded-lg px-3 py-2.5 text-[14px] text-[#30231D] focus:outline-none focus:border-[#A28161]">
                        <option value="admin">Admin</option>
                        <option value="staff">Staff</option>
                        <option value="customer">Customer</option>
                    </select>
                </div>

                <div>
                    <label class="block text-[12px] font-medium text-[#A28161] mb-1.5 uppercase tracking-wider">
                        รหัสผ่านใหม่ (เว้นว่างถ้าไม่เปลี่ยน)
                    </label>

                    <input type="text" name="newPassword" id="editPassword"
                        class="w-full border border-[#E0D5C8] rounded-lg px-3 py-2.5 text-[14px] text-[#30231D] focus:outline-none focus:border-[#A28161] font-mono"
                        placeholder="เว้นว่างถ้าไม่ต้องการเปลี่ยน">
                </div>

                <div class="flex gap-3 mt-2">
                    <button type="button" onclick="closeEditModal()"
                        class="flex-1 border border-[#E0D5C8] text-[#6E5742] text-[14px] py-2.5 rounded-lg hover:bg-[#F0EBE3] transition">
                        ยกเลิก
                    </button>
                    <button type="submit"
                        class="flex-1 bg-[#6E5742] hover:bg-[#5a4535] text-white text-[14px] py-2.5 rounded-lg transition font-medium">
                        บันทึก
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Delete -->
    <div id="deleteModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40">
        <div class="bg-white rounded-2xl shadow-xl w-[400px] p-7 text-center">
            <div class="w-12 h-12 bg-red-50 rounded-full flex items-center justify-center mx-auto mb-4">
                <svg class="w-6 h-6 text-red-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/>
                    <path d="M10 11v6M14 11v6M9 6V4a1 1 0 011-1h4a1 1 0 011 1v2"/>
                </svg>
            </div>
            <h3 class="text-[16px] font-semibold text-[#30231D] mb-2">
                ลบผู้ใช้
            </h3>
            <p class="text-[14px] text-[#A28161] mb-6">ต้องการลบ <span id="deleteUsername" class="font-semibold text-[#30231D]"></span> ออกจากระบบ?</p>
            <form action="/users/delete" method="POST" class="flex gap-3">
                <input type="hidden" name="id" id="deleteId">
                <button type="button" onclick="closeDeleteModal()"
                    class="flex-1 border border-[#E0D5C8] text-[#6E5742] text-[14px] py-2.5 rounded-lg hover:bg-[#F0EBE3] transition">
                    ยกเลิก
                </button>
                <button type="submit"
                    class="flex-1 bg-red-500 hover:bg-red-600 text-white text-[14px] py-2.5 rounded-lg transition font-medium">
                    ลบ
                </button>
            </form>
        </div>
    </div>

    <script>
        setTimeout(() => document.getElementById('flashMsg')?.remove(), 4000);

        // Search / Filter
        function filterTable() {
            const q = document.getElementById('searchInput').value.toLowerCase();
            const role = document.getElementById('roleFilter').value;
            document.querySelectorAll('.user-row').forEach(row => {
                const matchQ = !q || row.dataset.name.includes(q) || row.dataset.email.includes(q);
                const matchRole = !role || row.dataset.role === role;
                row.style.display = matchQ && matchRole ? '' : 'none';
            });
        }

        // สุ่ม Password
        function generatePassword() {
            const chars = 'ABCDEFGHJKMNPQRSTUVWXYZabcdefghjkmnpqrstuvwxyz23456789@#$!';
            let pass = '';
            for (let i = 0; i < 10; i++) pass += chars[Math.floor(Math.random() * chars.length)];
            document.getElementById('createPassword').value = pass;
        }

        function copyPassword() {
            const val = document.getElementById('createPassword').value;
            if (!val) return;
            navigator.clipboard.writeText(val).then(() => {
                const btn = event.currentTarget;
                btn.innerHTML = `<svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="20 6 9 18 4 13"/></svg>`;
                setTimeout(() => btn.innerHTML = `<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>`, 1500);
            });
        }

        // Generate username (format : staff_{nextId})
        const nextId = <%= nextId %>;
        function generateUsername() {
            const role = document.getElementById('createRole').value;
            document.getElementById('createUsername').value = `${role}_${nextId}`;
            document.getElementById('createEmail').value = `${role}${nextId}@kofy.com`;
        }

        function openCreateModal() {
            generateUsername();
            generatePassword();
            document.getElementById('createModal').classList.remove('hidden');
            document.getElementById('createModal').classList.add('flex');
        }
        function closeCreateModal() {
            document.getElementById('createModal').classList.add('hidden');
            document.getElementById('createModal').classList.remove('flex');
        }

        function openEditModal(u) {
            document.getElementById('editId').value = u.id;
            document.getElementById('editUsername').value = u.username;
            document.getElementById('editEmail').value = u.email;
            document.getElementById('editPhone').value = u.phone || '';
            document.getElementById('editRole').value = u.role;
            document.getElementById('editPassword').value = '';
            document.getElementById('editModal').classList.remove('hidden');
            document.getElementById('editModal').classList.add('flex');
        }
        function closeEditModal() {
            document.getElementById('editModal').classList.add('hidden');
            document.getElementById('editModal').classList.remove('flex');
        }

        function confirmDelete(id, name) {
            document.getElementById('deleteId').value = id;
            document.getElementById('deleteUsername').textContent = name;
            document.getElementById('deleteModal').classList.remove('hidden');
            document.getElementById('deleteModal').classList.add('flex');
        }
        function closeDeleteModal() {
            document.getElementById('deleteModal').classList.add('hidden');
            document.getElementById('deleteModal').classList.remove('flex');
        }

        ['createModal','editModal','deleteModal'].forEach(id => {
            document.getElementById(id).addEventListener('click', function(e) {
                if (e.target === this) {
                    this.classList.add('hidden');
                    this.classList.remove('flex');
                }
            });
        });
    </script>
</body>
</html>
