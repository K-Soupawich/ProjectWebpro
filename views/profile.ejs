<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Customer Page</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&family=Noto+Sans+Thai:wght@400;600;700;800;900&display=swap"
        rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', 'Noto Sans Thai', sans-serif;
        }
    </style>
</head>

<body style="font-family: 'Inter', 'Noto Sans Thai', sans-serif;" class="bg-[#F7F5F0] min-h-screen">
    <%- include("customer/navbar") %>

    <div class="max-w-[680px] mx-auto px-4 py-10">
        <div class="mb-4">
            <a href="<%= (user.role === 'admin' || user.role === 'staff') ? '/dashboard' : '/customer/shop' %>"
                class="flex items-center gap-2 text-sm text-gray-400 hover:text-[#6E5742] transition w-fit">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M15 19l-7-7 7-7"/>
                </svg>
                กลับ
            </a>
        </div>
        <!-- Profile Card -->
        <div class="bg-white rounded-3xl shadow-sm overflow-hidden">

            <div class="h-[90px] bg-gradient-to-r from-[#A28161] to-[#6E5742]"></div>

            <!-- Avatar -->
            <div class="flex flex-col items-center -mt-[55px] px-8 pb-8">
                <div class="relative group">
                    <img id="avatarImg"
                        src="/img/profile/<%= user.avatar %>"
                        onerror="this.src='/img/profile/default.png'"
                        class="w-[110px] h-[110px] rounded-full object-cover border-4 border-white shadow-md">
                    <!-- overlay เปลี่ยนรูป -->
                    <label id="avatarOverlay"
                        class="hidden absolute inset-0 rounded-full bg-black/40 flex items-center justify-center cursor-pointer">
                        <span class="text-white text-xs font-medium">
                            เปลี่ยนรูป
                        </span>
                        <input type="file" name="avatar" id="avatarInput" accept="image/*" class="hidden">
                    </label>
                </div>

                <h2 id="nameDisplay" class="mt-3 text-[22px] font-bold text-[#30231D]"><%= userData.username %></h2>
                <p class="text-sm text-gray-400 mt-0.5"><%= userData.role === 'customer' ? 'สมาชิก' : userData.role %></p>

                <div class="mt-6 w-full max-w-[460px] space-y-3">

                    <!-- Email -->
                    <div class="flex items-center gap-3 bg-[#FAF8F5] rounded-xl px-4 py-3">
                        <svg class="w-4 h-4 text-[#A28161] shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                        </svg>
                        <div class="flex-1 min-w-0">
                            <p class="text-[11px] text-gray-400">อีเมล</p>
                            <p id="emailDisplay" class="text-sm font-medium text-gray-700 truncate"><%= userData.email %></p>
                        </div>
                    </div>

                    <!-- Phone -->
                    <div class="flex items-center gap-3 bg-[#FAF8F5] rounded-xl px-4 py-3">
                        <svg class="w-4 h-4 text-[#A28161] shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                        </svg>
                        <div class="flex-1">
                            <p class="text-[11px] text-gray-400">เบอร์โทร</p>
                            <p class="text-sm font-medium text-gray-700"><%= userData.phone || '-' %></p>
                        </div>
                    </div>

                </div>

                <button onclick="openEdit()"
                    class="mt-5 flex items-center gap-2 bg-[#F3EDE6] hover:bg-[#ebe2d8] text-[#6E5742] text-sm font-semibold px-5 py-2 rounded-full transition">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                    </svg>
                    แก้ไขโปรไฟล์
                </button>
            </div>
        </div>

         <% if (user.role === 'customer') { %>
            <div class="mt-6">
                <h3 class="text-[15px] font-bold text-[#30231D] mb-3 px-1">สถานะคำสั่งซื้อ</h3>

                <% if (orders.length === 0) { %>
                    <div class="bg-white rounded-2xl shadow-sm p-8 text-center text-gray-400 text-sm">
                        ยังไม่มีคำสั่งซื้อ
                    </div>
                <% } else { %>
                    <div class="space-y-3">
                        <% orders.forEach(order => {
                            const statusMap = {
                                pending: { label: 'รอดำเนินการ', cls: 'bg-yellow-50 text-yellow-600' },
                                confirmed: { label: 'ยืนยันแล้ว', cls: 'bg-blue-50 text-blue-600' },
                                shipped: { label: 'กำลังจัดส่ง', cls: 'bg-indigo-50 text-indigo-600' },
                                delivered: { label: 'จัดส่งสำเร็จ', cls: 'bg-green-50 text-green-600' },
                                cancelled: { label: 'ยกเลิก', cls: 'bg-red-50 text-red-500' },
                            };
                            const st = statusMap[order.status] || { label: order.status, cls: 'bg-gray-100 text-gray-500' };
                        %>
                        <div class="bg-white rounded-2xl shadow-sm px-5 py-4 flex items-center justify-between gap-4">
                            <div class="flex items-center gap-3 min-w-0">
                                <div class="w-10 h-10 rounded-xl bg-[#F3EDE6] flex items-center justify-center shrink-0 text-[#A28161] font-bold text-sm">
                                    #<%= order.id %>
                                </div>
                                <div class="min-w-0">
                                    <p class="text-sm font-semibold text-gray-700 truncate"><%= order.item_count %> รายการ</p>
                                    <p class="text-xs text-gray-400">฿<%= order.total_amount.toLocaleString() %> · <%= new Date(order.created_at).toLocaleDateString('th-TH') %></p>
                                </div>
                            </div>
                            <span class="text-xs font-semibold px-3 py-1 rounded-full shrink-0 <%= st.cls %>">
                                <%= st.label %>
                            </span>
                        </div>
                        <% }) %>
                    </div>
                <% } %>
            </div>
        <% } %>

        <!-- Logout -->
        <div class="flex justify-center mt-8">
            <a href="/logout"
                class="flex items-center gap-2 text-sm text-gray-400 hover:text-[#6E5742] transition font-medium">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                </svg>
                ออกจากระบบ
            </a>
        </div>
    </div>

    <!-- Edit Modal -->
    <div id="editModal"
        class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/30 backdrop-blur-sm px-4">
        <div class="bg-white rounded-3xl shadow-xl w-full max-w-[420px] p-8 relative">
            <button onclick="closeEdit()" class="absolute top-4 right-5 text-gray-300 hover:text-gray-500 text-xl">✕</button>

            <h3 class="text-[18px] font-bold text-[#30231D] mb-6">แก้ไขโปรไฟล์</h3>

            <form action="/profile/update" method="POST" class="space-y-4" enctype="multipart/form-data">
                <!-- Avatar preview -->
                <div class="flex justify-center mb-2">
                    <div class="relative">
                        <img id="modalAvatar"
                            src="<%= userData.avatar ? '/img/profile/' + userData.avatar : '/img/profile/default.png' %>"
                            onerror="this.src='/img/profile/default.png'"
                            class="w-[80px] h-[80px] rounded-full object-cover border-2 border-[#e0d5c8]">
                        <label class="absolute bottom-0 right-0 bg-[#A28161] text-white rounded-full w-6 h-6 flex items-center justify-center cursor-pointer text-xs">
                            ✎
                            <input type="file" name="avatar" id="modalAvatarInput" accept="image/*" class="hidden" onchange="previewAvatar(this)">
                        </label>
                    </div>
                </div>

                <!-- Username -->
                <div>
                    <label class="text-xs text-gray-500 mb-1 block">ชื่อผู้ใช้</label>
                    <input type="text" name="username"
                        value="<%= userData.username %>"
                        class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-[#A28161] transition">
                </div>

                <!-- Email -->
                <div>
                    <label class="text-xs text-gray-500 mb-1 block">อีเมล</label>
                    <input type="email" name="email"
                        value="<%= userData.email %>"
                        class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-[#A28161] transition">
                </div>

                <!-- Phone -->
                <div>
                    <label class="text-xs text-gray-500 mb-1 block">เบอร์โทร</label>
                    <input type="text" name="phone"
                        value="<%= userData.phone || '' %>"
                        class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-[#A28161] transition">
                </div>

                <button type="submit"
                    class="w-full bg-gradient-to-r from-[#A28161] to-[#6E5742] text-white font-semibold py-3 rounded-xl hover:opacity-90 transition mt-2">
                    บันทึก
                </button>
            </form>
        </div>
    </div>

</body>

<script>
    function openEdit() {
        document.getElementById('editModal').classList.remove('hidden');
    }
    function closeEdit() {
        document.getElementById('editModal').classList.add('hidden');
    }
    // ปิด modal เมื่อคลิกนอก
    document.getElementById('editModal').addEventListener('click', function(e) {
        if (e.target === this) closeEdit();
    });

    function previewAvatar(input) {
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = e => {
                document.getElementById('modalAvatar').src = e.target.result;
                document.getElementById('avatarImg').src = e.target.result;
            };
            reader.readAsDataURL(input.files[0]);
        }
    }
</script>

</html>
