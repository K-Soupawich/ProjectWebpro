<!DOCTYPE html>
<html lang="th">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&family=Noto+Sans+Thai:wght@400;600;700;800;900&display=swap"
        rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', 'Noto Sans Thai', sans-serif;
        }

        .input-style {
            font-size: 28px;
            font-weight: 600;
            color: #7a7777;
            width: 100%;
            border: none;
            border-bottom: 1px solid #D9D9D9;
            padding: 17px 0;
            margin: 7px 0;
        }

        .input-style:focus {
            outline: none;
            border-bottom: 1px solid #8B6B4A;
        }
    </style>
    <title>ลงทะเบียน</title>
</head>

<body class="h-screen w-screen bg-gray-F8F7F3 flex items-center justify-center">
    <div class="flex h-full w-full">
        <a href="/" class="absolute top-4 right-6 text-gray-400 text-[25px] hover:text-gray-600">
            ✕
        </a>

        <!-- ฝั่งซ้าย -->
        <div class="w-1/2 relative">
            <img src="/img/login/login_bg.png" class="w-full h-full object-cover" />

            <div
                class="absolute inset-0 bg-[linear-gradient(68.66deg,#A28161_4.9%,#6E5742_69.48%,#3C3024_225.09%)] opacity-89">
            </div>

            <div class="absolute inset-0 flex items-center justify-center">
                <img src="/img/login/logo.png" class="w-[570px] -translate-y-16">
            </div>
        </div>

        <!-- ฝั่งขวา -->
        <div class="w-1/2 flex flex-col items-center justify-center px-20">

            <h2 class="font-semibold text-[36px] text-center mb-10">ลงทะเบียน</h2>

            <form id="register-form" action="/register" method="POST">
                <input type="text" class="input-style" name="username" required placeholder="ชื่อบัญชีผู้ใช้">
                <input type="text" class="input-style" name="phone" required placeholder="เบอร์โทร">
                <input type="email" class="input-style" name="email" required placeholder="อีเมล">
                <input type="password" class="input-style" name="password" required placeholder="รหัสผ่าน">
                <input type="password" class="input-style" name="confirm_password" required
                    placeholder="ยืนยันรหัสผ่าน">

                <div class="mt-16 flex flex-col items-center">
                    <button type="submit" form="register-form">
                        <img src="/img/login/register_btn.png" class="w-[500px] pb-0" />
                    </button>

                    <a href="/login" class="-mt-6 font-semibold text-[28px] text-[#A28161] underline underline-offset-2">เข้าสู่ระบบ</a>
                </div>
            </form>
        </div>
    </div>
    <% if (typeof error !== 'undefined' && error) { %>
        <div id="errorPopup" class="fixed top-6 left-1/2 -translate-x-1/2 z-50
            bg-red-50 border border-red-200 text-red-600 text-[14px] font-medium
            px-6 py-3 rounded-2xl shadow-lg flex items-center gap-3">
            
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
            </svg>
            
            <%= error %>
            <button onclick="document.getElementById('errorPopup').remove()" class="ml-2 text-red-400 hover:text-red-600">
                ✕
            </button>

        </div>
    <% } %>

    <% if (typeof success !== 'undefined' && success) { %>
        <div id="successPopup" class="fixed top-6 left-1/2 -translate-x-1/2 z-50
            bg-green-50 border border-green-200 text-green-600 text-[14px] font-medium
            px-6 py-3 rounded-2xl shadow-lg flex items-center gap-3">

            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M5 13l4 4L19 7"/>
            </svg>

            <%= success %>
        </div>
    <% } %>

    <script>
        function showError(msg) {
            document.getElementById('errorPopup')?.remove();
            const div = document.createElement('div');
            div.id = 'errorPopup';
            div.className = 'fixed top-6 left-1/2 -translate-x-1/2 z-50 bg-red-50 border border-red-200 text-red-600 text-[14px] font-medium px-6 py-3 rounded-2xl shadow-lg flex items-center gap-3';
            div.innerHTML = `
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
                </svg>
                <span>${msg}</span>
                <button onclick="document.getElementById('errorPopup').remove()" class="ml-2 text-red-400 hover:text-red-600">✕</button>
            `;
            document.body.appendChild(div);
            setTimeout(() => div.remove(), 4000);
        }

        // Validate ก่อน submit
        document.getElementById('register-form').addEventListener('submit', function(e) {
            const phone = this.phone.value.trim();
            const email = this.email.value.trim();

            const phoneRegex = /^[0-9]{10}$/;
            const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

            if (!phoneRegex.test(phone)) {
                e.preventDefault();
                showError('เบอร์โทรต้องเป็นตัวเลข 10 หลัก');
                return;
            }
            if (!emailRegex.test(email)) {
                e.preventDefault();
                showError('รูปแบบอีเมลไม่ถูกต้อง');
                return;
            }
        });
    </script>
</body>

</html>