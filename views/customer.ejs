<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Customer Page</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&family=Noto+Sans+Thai:wght@400;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', 'Noto Sans Thai', sans-serif;

        }
    </style>
</head>

<body style="font-family: 'Inter', 'Noto Sans Thai', sans-serif;" class="bg-[#F7F5F5]">
    <div class="bg-[#F8F8F8] h-[78px] flex items-center border-b border-gray-300 sticky top-0 z-50">
        <div class="ml-[60px]">
            <a href="/">
                <img src="/img/home/logo1.png" class="w-[100px] h-[67px]">
            </a>
        </div>

        <div class=" ml-[1070px]">
            <a href="/">
                <img src="/img/home/cart.png" class="w-[47px] h-[47px]">
            </a>
        </div>

        <div class="ml-[40px]">
            <img src="/img/profile/<%= user.name %>.png" class="w-[40px] h-[40px] rounded-full object-cover border">
        </div>
    </div>

    <div class="mt-[40px]">
        <form action="/search" method="GET" class="flex justify-center mt-4">
            <div class="relative w-[800px]">
                <input type="text" name="q" placeholder="ค้นหาสินค้า"
                    class="w-[800px] h-[40px] rounded-full border border-gray-300 pl-5 pr-12 outline-none bg-gray-100">

                <button type="submit" class="absolute right-4 top-1/2 -translate-y-1/2">                    
                    <img src="/img/customer/search.png" class="w-[20px]">
                </button>
            </div>
        </form>
    </div>

    <div class="flex text-center justify-center mt-[55px]">
        <div class="category w-[94px] mr-[82px] cursor-pointer">
            <a href="/customer/products?category=SH">
                <img src="/img/customer/หมวดเสื้อ.png" class="rounded-full hover:scale-105 transition duration-200">
            </a>
            <div class="mt-[15px]">
                <p>เสื้อ</p>
            </div>
        </div>

        <div class="category w-[94px] mr-[82px] cursor-pointer">
            <a href="/customer/products?category=CH">
                <img src="/img/customer/หมวดเสื้อแขนยาว.png" class="rounded-full hover:scale-105 transition duration-200">
            </a>
            <div class="mt-[15px]">
                <p>เสื้อแขนยาว</p>
            </div>
        </div>

        <div class="category w-[94px] mr-[82px] cursor-pointer">
            <a href="/customer/products?category=PN">
                <img src="/img/customer/หมวดกางเกง.png" class="rounded-full hover:scale-105 transition duration-200">
            </a>
            <div class="mt-[15px]">
                <p>กางเกง</p>
            </div>
        </div>

        <div class="category w-[94px] mr-[82px] cursor-pointer">
            <a href="/customer/products?category=SK">
                <img src="/img/customer/หมวดกระโปรง.png" class="rounded-full hover:scale-105 transition duration-200">
            </a>
            <div class="mt-[15px]">
                <p>กระโปรง</p>
            </div>
        </div>

        <div class="category w-[94px] mr-[82px] cursor-pointer">
            <a href="/customer/products?category=DR">
                <img src="/img/customer/หมวดเดรส.png" class="rounded-full hover:scale-105 transition duration-200">
            </a>
            <div class="mt-[15px]">
                <p>เดรส</p>
            </div>
        </div>

        <div class="category w-[94px] mr-[82px] cursor-pointer">
            <a href="/customer/products?category=UW">
                <img src="/img/customer/หมวดชุดชั้นใน.png" class="rounded-full hover:scale-105 transition duration-200">
            </a>
            <div class="mt-[15px]">
                <p>ชุดชั้นใน</p>
            </div>
        </div>
    </div>

    <div>
        //เส้นขั้น
    </div>

    <div>
        <% products.forEach(product => { %>
            <div>
                <img src="/uploads/<%= product.image %>">
                <p>
                    <%= product.name %>
                </p>
                <p>
                    <%= product.price %>
                </p>
                <a href="/login">
                    <img src="/img/home/cart.png" class="w-[26.65px]">
                </a>
            </div>
        <% }) %>
    </div>

    




</body>

</html>