<!DOCTYPE html>
<html lang="en">

    <%- include("head") %> 

<body style="font-family: 'Inter', 'Noto Sans Thai', sans-serif;" class="bg-[#F7F5F5]">
    <div>
        <%- include("navbar") %>
    </div>

    <div class="flex gap-15 items-center mt-[101px] mb-[75px] ml-[105px]">
        <button onclick="history.back()" class="cursor-pointer hover:scale-105 transition duration-200">
            <img src="/img/customer/back_button.png" class="w-[13px]">
        </button>
        <p class="text-[#30231D] font-bold text-[20px]">ตะกร้าสินค้า</p>
    </div>

    <div class="flex justify-center gap-7">
        <div class="bg-[#F8F8F8] w-[894px] h-[690px] rounded-[20px] border border-gray-200 shadow-sm sticky">
            <% products.forEach(product=> { %>
                <div class="flex">
                    <input type="checkbox" class="w-[22px] h-[22px]">
                    
                    <img src="/uploads/<%= product.image %>">

                    <div>
                        <p><%= product.name %></p>
                        <p>ขนาด: <%= product.size %></p>
                    </div>

                    <div class="flex items-center gap-2 bg-[#FEFCFC] w-[175px] h-[48px] rounded-[40px] border border-gray-200 mb-[8px]">
                        <button type="button" onclick="decrease()" class="cursor-pointer ml-[20px] text-[20px]">-</button>
                        <input id="num" type="text" value="1" class="w-[94px] text-center text-[16px]">
                        <button type="button" onclick="increase()" class="cursor-pointer text-[20px]">+</button>
                    </div>

                    <h2 class="text-[32px] font-bold text-[#30231D]">฿<%= product.price %></h2>
                </div>
                <% }) %>
        </div>

        <div class="bg-[#F8F8F8] w-[413px] h-[348px] rounded-[20px] border border-gray-200 shadow-sm p-[30px]">
            
            
            <p class="text-[20px] font-bold mb-[29px]">สรุปคำสั่งซื้อ</p>
            
            <div class="flex justify-between mb-[21px]">
                <p>ยอดรวมทั้งหมด</p>
                <p>฿เงิน</p>
            </div>
            <div class="flex justify-between mb-[27px]">
                <p>ค่าจัดส่ง</p>
                <p>฿50</p>
            </div>
            <div>
                <hr class="mx-[10px] border-gray-300 mb-[18px]">
            </div>
            <div class="flex justify-between mb-[41px]">
                <p class="text-[18px] font-semibold">ยอดรวมสุทธิ</p>
                <p >฿เงินรวม</p>
            </div>
            <div class="flex justify-center">
                <a href="#">
                    <img src="/img/customer/ชำระเงิน.png" class="w-[313px] hover:scale-105 transition duration-200">
                </a>
            </div>
        
        </div>
    </div>

    <script>
        function increase(){
            let num = parseInt(document.getElementById("num").value);

            if (num >= 1) {
                document.getElementById("num").value = num + 1;
            }
        }

        function decrease(){
            let num = parseInt(document.getElementById("num").value);

            if (num > 1) {
                document.getElementById("num").value = num - 1;
            }
        }
    </script>


</body>
</html>